# =============================================
# Angular / MFE Architecture - .gitignore
# =============================================

# ---------------------------
# Node / npm
# ---------------------------
node_modules/
npm-debug.log
npm-debug.log.*
yarn-error.log
.npm
.yarn-integrity

# ---------------------------
# Angular Build Outputs
# ---------------------------
dist/
tmp/
out-tsc/
bazel-out/

# Angular CLI cache
.angular/

# ---------------------------
# Angular Library Build
# ---------------------------
component-library/dist/

# ---------------------------
# Compodoc Generated Docs
# ---------------------------
component-library-showcase/public/docs/

# ---------------------------
# Module Federation
# ---------------------------
# Uncomment if you generate federation manifests at build time
# shell-app/public/federation.manifest.json

# ---------------------------
# Environment / Secrets
# ---------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ---------------------------
# IDE & Editor
# ---------------------------

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# ---------------------------
# OS Generated Files
# ---------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ---------------------------
# Testing & Coverage
# ---------------------------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
cypress/screenshots/
cypress/videos/

# ---------------------------
# Logs & Diagnostics
# ---------------------------
logs/
*.log
*.log.*
pids/
*.pid
*.seed
*.pid.lock

# ---------------------------
# federation-config package
# ---------------------------
# This package is published to a private registry in production.
# The node_modules here are only present when testing locally via file: path.
federation-config/node_modules/

# ---------------------------
# Miscellaneous
# ---------------------------
*.tgz
*.tar.gz
*.zip
*.bak
*.orig
nul
